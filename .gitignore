# ==========================================
# MediAlert .gitignore
# ==========================================

# ==========================================
# Android 相关
# ==========================================
*.apk
*.aab
*.ap_
*.dex
*.class

# 构建输出
/build/
/app/build/
/captures/
.externalNativeBuild/
.cxx/
local.properties

# ==========================================
# Gradle 相关
# ==========================================
/.gradle/
**/build/
gradle-app.setting
!gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ==========================================
# IDE 相关 - Android Studio / IntelliJ
# ==========================================
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/

# ==========================================
# 签名文件
# ==========================================
*.jks
*.keystore
signing.properties

# ==========================================
# 系统文件
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ==========================================
# 日志和临时文件
# ==========================================
*.log
*.tmp
*.bak
*.swp
*~

# ==========================================
# 测试和覆盖率
# ==========================================
**/test-results/
**/test-output/
jacoco.exec
*.ec
*.exec
coverage-report/
htmlcov/

# ==========================================
# 文档生成（如不需要跟踪）
# ==========================================
**/generated/
**/generatedFiles/
**/gen/
**/bin/

# ==========================================
# KSP 生成文件
# ==========================================
**/ksp/
**/generated/ksp/

# ==========================================
# 本地配置（不同机器不同配置）
# ==========================================
*.local
*.local.properties
env.properties

# ==========================================
# 构建产物（APK/AAB 输出目录）
# ==========================================
app/release/

# ==========================================
# IDE 缓存（自动生成，不应共享）
# ==========================================
.idea/caches/
.idea/modules/
.idea/libraries/

# ==========================================
# 运行时 / 构建工具生成文件
# ==========================================
*.hprof
*.crc
*.pid
*.seed
debug.keystore

# ==========================================
# 合并冲突备份
# ==========================================
*.orig
*.rej

# ==========================================
# 敏感配置（预防性提交）
# ==========================================
google-services.json
secrets.properties
apikeys.properties
