# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for shell scripts
*.sh text eol=lf
gradlew text eol=lf

# Force CRLF for Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.apk binary
*.aab binary
*.jks binary
*.keystore binary
